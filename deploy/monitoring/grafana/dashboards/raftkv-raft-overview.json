{
  "uid": "raftkv-raft-overview",
  "title": "RaftKV - Raft Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": ["raftkv", "raft", "prometheus"],
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "RPC rate (outbound) - AppendEntries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (from, ok) (rate(raft_rpc_total{method=\"AppendEntries\"}[10s]))",
          "legendFormat": "from={{from}} ok={{ok}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RPC latency p50/p95 (ok=true) - AppendEntries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, from) (rate(raft_rpc_duration_seconds_bucket{method=\"AppendEntries\", ok=\"true\"}[1m])))",
          "legendFormat": "from={{from}} p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le, from) (rate(raft_rpc_duration_seconds_bucket{method=\"AppendEntries\", ok=\"true\"}[1m])))",
          "legendFormat": "from={{from}} p50"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Start index",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "raft_start_index",
          "legendFormat": "node={{node}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Commit index",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "raft_commit_index",
          "legendFormat": "node={{node}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Last applied",
      "datasource": "Prometheus",
